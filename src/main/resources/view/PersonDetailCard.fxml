<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox id="cardPane" fx:id="cardPane" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <GridPane HBox.hgrow="ALWAYS">
        <columnConstraints>
            <ColumnConstraints hgrow="SOMETIMES" minWidth="10" prefWidth="150" />
        </columnConstraints>
        <VBox alignment="CENTER_LEFT" minHeight="105" styleClass="label-bright" GridPane.columnIndex="0" >
            <padding>
                <Insets top="10" right="5" bottom="10" left="5" />
            </padding>
            <Label fx:id="name" text="\$first" styleClass="card_big_label" />
            <Label fx:id="phone" styleClass="card_small_label" text="\$phone" />
            <Label fx:id="email" styleClass="card_small_label" text="\$email" />
            <Label fx:id="address" styleClass="card_small_label" text="\$address" />
            <Label fx:id="notes" styleClass="card_small_label" text="\$notes" />
            <FlowPane fx:id="tags" styleClass="label" />
        </VBox>
    </GridPane>
</HBox>
