@startuml
!include style.puml
skinparam ArrowFontStyle plain

Actor User as user USER_COLOR
Participant ":UI" as ui UI_COLOR
Participant ":Logic" as logic LOGIC_COLOR
Participant ":Model" as model MODEL_COLOR
Participant ":Storage" as storage STORAGE_COLOR

user -[USER_COLOR]> ui : "add ~--name=Amy Tan ~--phone=91234567\n ~--email=amy@example.com ~--address=123 Clementi Rd"
activate ui UI_COLOR

ui -[UI_COLOR]> logic : execute(commandText)
activate logic LOGIC_COLOR

logic -[LOGIC_COLOR]> model : addPerson(client)
activate model MODEL_COLOR

model -[MODEL_COLOR]-> logic : updated in-memory data
deactivate model

logic -[LOGIC_COLOR]> storage : saveAddressBook(addressBook)
activate storage STORAGE_COLOR

storage -[STORAGE_COLOR]> storage : write JSON file
activate storage STORAGE_COLOR_T1
storage --[STORAGE_COLOR]> storage
deactivate storage

storage --[STORAGE_COLOR]> logic : save successful
deactivate storage

logic --[LOGIC_COLOR]> ui : CommandResult
deactivate logic

ui--[UI_COLOR]> user : success message shown
deactivate ui
@enduml
